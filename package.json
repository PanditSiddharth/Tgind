{
  "name": "tgind",
  "version": "1.0.1",
  "description": "Telegram bot api which gives you simplest way to make your bots",
  "directories": {
    "example": "examples",
    "lib": "lib"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "form-data": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.1.3"
  },
  "main": "lib/index.js",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./lib/index.js"
    },
    "./classes": {
      "types": "./classes.d.ts",
      "default": "./lib/classes.js"
    }
  },
  "files": [
    "tgind/**/*.ts",
    "lib/**/*.js",
    "types/**/*.d.ts",
    "types/**/*.d.ts.map"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PanditSiddharth/Tgind.git"
  },
  "keywords": [],
  "author": "PanditSiddharth",
